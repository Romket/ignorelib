{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 14,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "default",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "hidden": true
    },
    {
      "name": "dev",
      "description": "Base preset for library developers",
      "hidden": true,
      "inherits": ["default"],
      "cacheVariables": {
        "IGNORELIB_BUILD_TESTS": "ON",
        "IGNORELIB_BUILD_EXAMPLES": "ON"
      }
    },
    {
      "name": "dev-win",
      "description": "Windows preset for library developers",
      "hidden": false,
      "inherits": ["dev"],
      "cacheVariables": {
        "CMAKE_CXX_FLAGS": "/W4 /EHsc /w14242 /w14254 /w14263 /w14265 /w14287 /w14289 /w14296 /w14311 /w14545 /w14546 /w14547 /w14549 /w14555 /w14640 /w14826 /w14928 /WX"
      }
    },
    {
      "name": "dev-linux",
      "description": "Linux preset for library developers",
      "hidden": false,
      "inherits": ["dev"],
      "cacheVariables": {
        "CMAKE_CXX_FLAGS": "-Wall -Wextra -Wpedantic -Wshadow -Wconversion -Wsign-conversion -Wcast-align -Wcast-qual -Wnull-dereference -Woverloaded-virtual -Wformat=2"
      }
    },
    {
      "name": "rel",
      "description": "Base release preset",
      "hidden": true,
      "inherits": ["default"],
      "cacheVariables": {
        "IGNORELIB_BUILD_TESTS": "OFF",
        "IGNORELIB_BUILD_EXAMPLES": "OFF"
      }
    },
    {
      "name": "rel-win",
      "description": "Windows release preset",
      "hidden": false,
      "inherits": ["rel"],
      "cacheVariables": {
        "CMAKE_CXX_FLAGS": "/02"
      }
    },
    {
      "name": "rel-linux",
      "description": "Linux release preset",
      "hidden": false,
      "inherits": ["rel"],
      "cacheVariables": {
        "CMAKE_CXX_FLAGS": "-Ofast -march=native -flto -funroll-loops -fprefetch-loop-arrays -fopenmp -fprofile-generate"
      }
    },
    {
      "name": "relminsize-win",
      "description": "Windows release preset with minimum compiled size",
      "hidden": false,
      "inherits": ["rel"],
      "cacheVariables": {
        "CMAKE_CXX_FLAGS": "/01"
      }
    },
    {
      "name": "relminsize-linux",
      "description": "Linux release preset with minimum compiled size",
      "hidden": false,
      "inherits": ["rel"],
      "cacheVariables": {
        "CMAKE_CXX_FLAGS": "-Os -march=native -flto"
      }
    }
  ]
}
